{
    "name": "fusion-project-site",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev --port 8000 --host 0.0.0.0",
        "build": "vite build",
        "preview": "vite preview --port 8000 --host 0.0.0.0",
